# ── Supabase (required) ───────────────────────────────────────────────────────
# Find these in your Supabase project → Settings → API
# NEXT_PUBLIC_ prefix means these are embedded at build time and safe to expose
# to the browser — the anon key is intentionally public (RLS enforces access).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-only, never expose to client code or NEXT_PUBLIC_ vars.
# Not used in the current codebase; reserved for future admin operations.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App URL (required) ────────────────────────────────────────────────────────
# Used for auth redirects (password reset emails, etc.).
# Set to your Vercel deployment URL in production: https://your-app.vercel.app
# Vercel sets VERCEL_URL automatically but it lacks the https:// scheme, so set
# this explicitly in Vercel → Settings → Environment Variables.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── OpenAI (optional) ─────────────────────────────────────────────────────────
# Required only if using the AI assistant (/api/ai/assistant).
# The route returns HTTP 503 with a clear hint if this key is absent.
# Add this in Vercel → Settings → Environment Variables (server-side only).
# NEVER prefix with NEXT_PUBLIC_ — this must never reach the browser.
OPENAI_API_KEY=sk-...
